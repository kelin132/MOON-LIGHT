# Copy this file to .env.local for local dev, and set the same keys
# in Vercel → Project Settings → Environment Variables for production.
# NEVER commit the real .env.local file.

# MongoDB connection string (the one from your bot's existing cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Moonlight

# The exact DB name your bot uses (if not embedded in the URI above)
MONGODB_DB_NAME=moonlight

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-byte-secret
NEXTAUTH_URL=http://localhost:3000

# Public site URL used for Open Graph / canonical links (prod value in Vercel)
NEXT_PUBLIC_SITE_URL=https://moonlighthaven.example.com
